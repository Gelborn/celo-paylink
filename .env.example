# Private wallet / deployment config
# Only replace this when deploying; frontend preview URLs do not need a private key.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# Optional: used by the Hardhat verify scripts for explorer verification.
# Keep explorer API keys private; do not prefix them with NEXT_PUBLIC_.
ETHERSCAN_API_KEY=
CELOSCAN_API_KEY=

# Private RPC endpoints for Hardhat and scripts
CELO_MAINNET_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Public frontend contract config
# Leave blank only for walletless local previews; production public routes need the matching deployed address.
NEXT_PUBLIC_CONTRACT_ADDRESS_MAINNET=
NEXT_PUBLIC_CONTRACT_ADDRESS_SEPOLIA=
# Use decimal deployment block heights so payment history starts at the contract deploy.
# Keep each deployment block paired with the matching network contract address.
NEXT_PUBLIC_CONTRACT_DEPLOYMENT_BLOCK_MAINNET=
NEXT_PUBLIC_CONTRACT_DEPLOYMENT_BLOCK_SEPOLIA=

# Private script-only contract config
# Use the deployed PayLinkProfile address when running verify or seed scripts.
PAYLINK_CONTRACT_ADDRESS_MAINNET=
PAYLINK_CONTRACT_ADDRESS_SEPOLIA=

# Public app config
# Use the final HTTPS origin without a trailing slash or path so metadata and receipt links share one origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Use celoSepolia while testing and celo for mainnet production.
# Use the exact value `celo` for mainnet; any other value falls back to celoSepolia.
# Keep this aligned with the matching public contract address and deployment block.
NEXT_PUBLIC_DEFAULT_CHAIN=celoSepolia
# Browser-facing RPC endpoints used by public pages and receipts; do not include private RPC credentials.
NEXT_PUBLIC_CELO_MAINNET_RPC_URL=https://forno.celo.org
NEXT_PUBLIC_CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
